# Copy this file to src/.env when running without Docker (local PostgreSQL + Redis)

# Environment
ENVIRONMENT="local"

# Application
APP_NAME="Your app name here"
APP_DESCRIPTION="Your app description here"
APP_VERSION="0.1"

# Database (local Postgres running on the host)
POSTGRES_USER="your_postgres_user"
POSTGRES_PASSWORD="your_password"
# Use loopback so the app connects to the host Postgres, not a container hostname
POSTGRES_SERVER="127.0.0.1"
POSTGRES_PORT=5432
POSTGRES_DB="your_database_name"

# Redis (local Redis instance)
REDIS_CACHE_HOST="127.0.0.1"
REDIS_CACHE_PORT=6379

REDIS_QUEUE_HOST="127.0.0.1"
REDIS_QUEUE_PORT=6379

REDIS_RATE_LIMIT_HOST="127.0.0.1"
REDIS_RATE_LIMIT_PORT=6379

REDIS_SESSION_HOST="127.0.0.1"
REDIS_SESSION_PORT=6379
REDIS_SESSION_DB=1
REDIS_SESSION_PASSWORD=

# Sessions & Security
SESSION_SECRET_KEY="change-this-session-secret"
SECRET_KEY="your-generated-secret-key"
ALGORITHM="HS256"

# OIDC (if used)
OIDC_ENABLED=false
OIDC_POST_LOGIN_REDIRECT="http://localhost:3000/auth-complete"

# CORS (adjust for production)
CORS_ORIGINS=["http://localhost:3000"]
