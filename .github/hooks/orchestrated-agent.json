{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Stateful orchestrated agent hooks for session context, prompt routing hints, tool gating, and session logging",
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "node .github/hooks/scripts/orchestrated_session_start.mjs",
        "windows": "node .github\\hooks\\scripts\\orchestrated_session_start.mjs",
        "timeout": 10
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "node .github/hooks/scripts/orchestrated_user_prompt.mjs",
        "windows": "node .github\\hooks\\scripts\\orchestrated_user_prompt.mjs",
        "timeout": 10
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "node .github/hooks/scripts/orchestrated_pre_tool.mjs",
        "windows": "node .github\\hooks\\scripts\\orchestrated_pre_tool.mjs",
        "timeout": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "node .github/hooks/scripts/orchestrated_post_tool.mjs",
        "windows": "node .github\\hooks\\scripts\\orchestrated_post_tool.mjs",
        "timeout": 15
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node .github/hooks/scripts/orchestrated_stop.mjs",
        "windows": "node .github\\hooks\\scripts\\orchestrated_stop.mjs",
        "timeout": 10
      }
    ]
  }
}